
===== bash =====

# awk template
awk 'BEGIN {} !/regex pattern/ {exit} /regex pattern/ {print} END {print NR}' 
awk -F"," '{print $1, $3}' filename # set separator, print 1st and 3rd column
awk -F"," '{sum += $3} END {print sum}'
awk -v myvar="$foo" 'BEGIN {print "My variable is:", myvar}'

# bc tamplate
echo "scale=3; sqrt(7 / 5)" | bc -l
echo "obase=2; 22" | bc # decimal to binary 
echo "$((2#10110))" # binary to decimal
echo 'n=8; m=10; if(n>m) {print "n is greater"} else {print "m is greater"}' | bc -l

# string processing
grep -o . # print each character in new line
echo "apple" | grep -o . | sort | uniq | wc -l
echo 'A_p p!l?E' | tr -cd [:alpha:] | tr [:upper:] [:lower:] # "apple"
IFS=',' read -r -a arr <<< "apple, banana, orange" # arr=(apple banana orange)

# argument parsing
while getops ":w:cb:" option; do # flags -w, -c, -b; -w and -b require argument
  case $option in
    w) echo "$OPTARG" ;;
    *) ;;
  esac
done

# environment
export # to show current shell attributes
compgen -A function # to show available functions


===== git =====

# check status
git status
git fetch

# update local repo from gihub
git pull --rebase origin main # if diverged

# add, rm and commit
git add .
git rm --cached .DS_Store
git commit -m "Made changes"

# reset last commit
git reset HEAD~1
git reset --hard HEAD~1 # discard changes

# push local changes to github
git push origin main


===== stow =====

# create symlinks
stow bash
stow .

# delete symlinks
stow -D bash



===== uv =====

# project setup
uv init
uv add httpx # to install package and add it to dependencies
uv add --dev httpx # add in dev dependency group
uv remove httpx
uv sync # synchronize with uv.lock

# python
uv python list
uv python install 3.12
uv pin 3.11 # lock project to specific Python version
uv pip list
uv pip install -r requirements.txt
uv pip compile pyproject.toml -o requirements.txt # generate req file
uv pip freeze # print installed packaged in req. format

# install
uv pip install -e . # editable installation
uv tool install -e .
uv tool install https://github.com/username/repo.git

